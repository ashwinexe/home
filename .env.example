# Gaming Status (for manual updates)
# Generate a random secret for API protection
GAMING_STATUS_SECRET=your_secret_key_here

# Layout edit mode write key (server-only, used with ?edit=1&key=... locally)
LAYOUT_EDIT_KEY=your_edit_key_here

# Blog previews
# Set to true locally to include draft: true and future-dated posts.
SHOW_DRAFTS=false

# Private vault
# Server-only owner key used to unlock /vault/login.
VAULT_OWNER_SECRET=your_private_vault_key_here
# Server-only random secret used to sign the HttpOnly vault session cookie.
VAULT_COOKIE_SECRET=generate_a_long_random_secret_here

# Spotify music widget
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token
# Optional static fallback embed used before OAuth is configured
NEXT_PUBLIC_SPOTIFY_EMBED_URL=https://open.spotify.com/embed/track/5QOBT97OmYCZo1W5u7tRrB?utm_source=generator

# Hashnode import
HASHNODE_HOST=ashwinexe.hashnode.dev
HASHNODE_TOKEN=your_hashnode_personal_access_token
